# ==========================================
# System Configuration
# ==========================================

# API version (usado no prefixo das rotas)
API_VERSION=v1

# System state: 'dev' for development or 'prod' for production
SYSTEM_STATE=dev

# Port number for the server to listen on
PORT=3000

# Comma-separated list of allowed origins for CORS (usado apenas em 'prod')
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ==========================================
# Oracle DB Connection
# ==========================================

# Database host address (ex: localhost ou IP da nuvem)
DB_HOST=localhost

# Database port number (padrão Oracle é 1521)
DB_PORT=1521

# Database service name (ex: FREEPDB1, XEPDB1 ou ORCL)
DB_SERVICE_NAME=FREEPDB1

# Database application user & password
DB_USER=api_partner_user
DB_PASSWORD="YourStrongPassword123!"

# Database admin user & password (necessário para rodar o seed.js e criar usuários)
DB_ADMIN_USER=system
DB_ADMIN_PASSWORD="YourAdminPassword123!"

# Database logging level: 'dev' (mostra as queries SQL no console) ou 'prod'
DB_LOGGING=dev